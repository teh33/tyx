#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

cleanup() {
  rm -rf \
    fixtures/node-basic/project.tyx \
    fixtures/node-basic/tyx.lock \
    fixtures/node-compose/project.tyx \
    fixtures/node-compose/tyx.lock \
    fixtures/node-version/project.tyx \
    fixtures/node-version/tyx.lock \
    fixtures/mismatch/tyx.lock \
    fixtures/missing-files/tyx.lock \
    fixtures/deps-present/tyx.lock \
    fixtures/node-basic/node_modules \
    fixtures/node-compose/node_modules
}

cleanup
trap cleanup EXIT
mkdir -p bin
export PATH="$PWD/fixtures/bin:$PATH"
odin check src
odin build src -out:bin/tyx
./bin/tyx init fixtures/node-basic >/tmp/tyx-basic.out
diff -u fixtures/node-basic/expected.project.tyx fixtures/node-basic/project.tyx
./bin/tyx init fixtures/node-compose >/tmp/tyx-compose.out
diff -u fixtures/node-compose/expected.project.tyx fixtures/node-compose/project.tyx
./bin/tyx init fixtures/node-version >/tmp/tyx-node-version.out
diff -u fixtures/node-version/expected.project.tyx fixtures/node-version/project.tyx
if ./bin/tyx init fixtures/multi-lock >/tmp/tyx-multi-lock.out 2>&1; then
  echo "expected multi-lock fixture to fail" >&2
  exit 1
fi
grep -q "Multiple package manager lockfiles" /tmp/tyx-multi-lock.out
./bin/tyx up fixtures/node-basic >/tmp/tyx-up-basic.out
diff -u fixtures/node-basic/expected.tyx.lock fixtures/node-basic/tyx.lock
./bin/tyx up fixtures/node-compose >/tmp/tyx-up-compose.out
diff -u fixtures/node-compose/expected.tyx.lock fixtures/node-compose/tyx.lock
grep -q "docker compose up compose.yaml compose.override.yaml -d" /tmp/tyx-up-compose.out
./bin/tyx up fixtures/mismatch >/tmp/tyx-up-mismatch.out
diff -u fixtures/mismatch/expected.tyx.lock fixtures/mismatch/tyx.lock
grep -q "node 20 mismatch" /tmp/tyx-up-mismatch.out
grep -q "Use node 20; found v22.13.1 on PATH." /tmp/tyx-up-mismatch.out
./bin/tyx up fixtures/missing-files >/tmp/tyx-up-missing-files.out
diff -u fixtures/missing-files/expected.tyx.lock fixtures/missing-files/tyx.lock
grep -q "compose missing.compose.yaml missing" /tmp/tyx-up-missing-files.out
grep -q "Create .env or remove it from project.tyx." /tmp/tyx-up-missing-files.out
./bin/tyx up fixtures/deps-present >/tmp/tyx-up-deps-present.out
diff -u fixtures/deps-present/expected.tyx.lock fixtures/deps-present/tyx.lock
grep -q "npm dependencies present" /tmp/tyx-up-deps-present.out
grep -q "pnpm install complete" /tmp/tyx-up-basic.out
grep -q "pnpm dependencies present" /tmp/tyx-up-basic.out
./bin/tyx down fixtures/node-compose >/tmp/tyx-down-compose.out
grep -q "docker compose down compose.yaml compose.override.yaml" /tmp/tyx-down-compose.out
./bin/tyx down fixtures/run >/tmp/tyx-down-run.out
grep -q "no runtime services declared" /tmp/tyx-down-run.out

# Negative parser/validation fixtures
if ./bin/tyx parse fixtures/invalid/no-project.tyx >/tmp/tyx-invalid-no-project.out 2>&1; then
  echo "expected no-project fixture to fail" >&2
  exit 1
fi
grep -q 'missing the `project:` header' /tmp/tyx-invalid-no-project.out
if ./bin/tyx parse fixtures/invalid/unknown-section.tyx >/tmp/tyx-invalid-unknown.out 2>&1; then
  echo "expected unknown-section fixture to fail" >&2
  exit 1
fi
grep -q 'section `wat`' /tmp/tyx-invalid-unknown.out
if ./bin/tyx parse fixtures/invalid/malformed-tool.tyx >/tmp/tyx-invalid-tool.out 2>&1; then
  echo "expected malformed-tool fixture to fail" >&2
  exit 1
fi
grep -q 'must be `<tool> <version>`' /tmp/tyx-invalid-tool.out
if ./bin/tyx parse fixtures/invalid/unsupported-tool.tyx >/tmp/tyx-invalid-unsupported-tool.out 2>&1; then
  echo "expected unsupported-tool fixture to fail" >&2
  exit 1
fi
grep -q 'tool `python`' /tmp/tyx-invalid-unsupported-tool.out
if ./bin/tyx parse fixtures/invalid/qualified-tools.tyx >/tmp/tyx-invalid-qualified-tools.out 2>&1; then
  echo "expected qualified-tools fixture to fail" >&2
  exit 1
fi
grep -q 'Qualified `tools` section' /tmp/tyx-invalid-qualified-tools.out
if ./bin/tyx parse fixtures/invalid/bad-script.tyx >/tmp/tyx-invalid-bad-script.out 2>&1; then
  echo "expected bad-script fixture to fail" >&2
  exit 1
fi
grep -q "Script entry" /tmp/tyx-invalid-bad-script.out
if ./bin/tyx parse fixtures/invalid/bad-quote.tyx >/tmp/tyx-invalid-bad-quote.out 2>&1; then
  echo "expected bad-quote fixture to fail" >&2
  exit 1
fi
grep -q "Unterminated quoted token" /tmp/tyx-invalid-bad-quote.out

./bin/tyx parse fixtures/node-basic/project.tyx >/tmp/tyx-parse.out
./bin/tyx run echo hello >/tmp/tyx-run.out
grep -q hello /tmp/tyx-run.out
./bin/tyx run --path fixtures/run hello >/tmp/tyx-run-script.out
grep -q hello /tmp/tyx-run-script.out
./bin/tyx run --path fixtures/run "hello world" >/tmp/tyx-run-quoted-script.out
grep -q "hello world" /tmp/tyx-run-quoted-script.out
echo "verify ok"
